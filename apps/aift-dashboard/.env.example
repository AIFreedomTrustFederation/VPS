# AI Freedom Trust Dashboard
# Copy to .env on the VPS or configure in Coolify.

AIFT_DASHBOARD_TOKEN="change-this-long-random-token"
AIFT_NODE_TOKEN="change-this-long-random-node-token"
AIFT_REGISTRY_PATH="/opt/aift/registry/apps.yml"
AIFT_NODES_PATH="/opt/aift/registry/nodes.yml"
AIFT_TEMPLATES_PATH="/opt/aift/registry/templates.yml"
AIFT_BUILDS_PATH="/opt/aift/registry/builds.yml"
AIFT_DEPLOYMENTS_PATH="/opt/aift/registry/deployments.yml"
AIFT_LOG_PATH="/opt/aift/logs"
AIFT_USER_SECRETS_PATH="/opt/aift/secrets/users"
COOLIFY_URL="https://vps.aifreedomtrust.com"
COOLIFY_API_TOKEN=""

# Browser/mobile source-control connection
AIFT_GITHUB_APP_NAME="AIFT Cloud Connector"
AIFT_GITHUB_APP_INSTALL_URL=""
AIFT_GITHUB_CALLBACK_URL="https://vps.aifreedomtrust.com/api/source/callback"
AIFT_GITHUB_APP_ID=""
AIFT_GITHUB_CLIENT_ID=""
